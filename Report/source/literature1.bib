@article{Handa2024,
   abstract = {Recent work has demonstrated the ability of deep reinforcement learning (RL) algorithms to learn complex robotic behaviours in simulation, including in the domain of multi-fingered manipulation. However, such models can be challenging to transfer to the real world due to the gap between simulation and reality. In this paper, we present our techniques to train a) a policy that can perform robust dexterous manipulation on an anthropomorphic robot hand and b) a robust pose estimator suitable for providing reliable real-time information on the state of the object being manipulated. Our policies are trained to adapt to a wide range of conditions in simulation. Consequently, our vision-based policies significantly outperform the best vision policies in the literature on the same reorientation task and are competitive with policies that are given privileged state information via motion capture systems. Our work reaffirms the possibilities of sim-to-real transfer for dexterous manipulation in diverse kinds of hardware and simulator setups, and in our case, with the Allegro Hand and Isaac Gym GPU-based simulation. Furthermore, it opens up possibilities for researchers to achieve such results with commonly-available, affordable robot hands and cameras. Videos of the resulting policy and supplementary information, including experiments and demos, can be found at https://dextreme.org/},
   author = {Ankur Handa and Arthur Allshire and Viktor Makoviychuk and Aleksei Petrenko and Ritvik Singh and Jingzhou Liu and Denys Makoviichuk and Karl Van Wyk and Alexander Zhurkevich and Balakumar Sundaralingam and Yashraj Narang and Jean-Francois Lafleche and Dieter Fox and Gavriel State},
   month = {1},
   note = {The paper “DeXtreme: Transfer of Agile In‑hand Manipulation from Simulation to Reality” presents a system for learning dexterous in‑hand manipulation that works on a commercially available 4‑fingered Allegro hand. The authors train a reinforcement‑learning policy in simulation using the GPU‑based Isaac Gym physics engine. They then transfer this policy to the real robot by combining extensive domain randomisation with a vision‑based pose estimator trained entirely from synthetic images. Compared with previous work that used expensive hardware and motion‑capture systems, the DeXtreme system uses low‑cost hardware, no marker‑based tracking, and orders‑of‑magnitude less compute. The resulting policies perform agile object reorientation: they repeatedly move a cube placed on the palm of the Allegro hand to random orientations without dropping it. In real‑world experiments, their best vision‑based policy achieved an average of 27.8 consecutive successes (with a peak of 112 successes in one run), outperforming earlier vision‑based systems while using cheaper hardware.<br/>Important ideas and contributions (with formulas)<br/><br/>1. Formulating dexterous in‑hand manipulation as a POMDP and training with PPO<br/>- Task definition: At each trial the object (a cube with coloured stickers for visual pose estimation) is initially placed on the robot’s palm, a random target orientation is sampled, and the policy must re‑orient the cube to this orientation. When the cube’s orientation is within 0.4 rad of the target, a new target is sampled, and the count of consecutive successes increases. The agent must avoid dropping the object.<br/>- Reinforcement‑learning formulation: The manipulation problem is cast as a partially observable Markov decision process (POMDP). The policy (actor) maps noisy observations (e.g., estimated object pose, target orientation, joint angles, last actions) to actions, while the value network (critic) receives additional privileged information, such as true fingertip velocities and forces. Observations used by the actor and critic are summarised in Table 1 of the paper.<br/>- Policy architecture: Proximal Policy Optimisation (PPO) is used as the RL algorithm. The actor is a recurrent (LSTM) network with 1024 hidden units followed by fully connected layers; the action space consists of 16 joint position targets for the Allegro hand. An exponential moving average low‑pass filter is applied to actions to ensure smooth, hardware‑safe motions.<br/><br/>2. Reward shaping for robust manipulation<br/>- The reward combines multiple terms to encourage accurate reorientation, retention of the cube and smooth actions. The per‑timestep reward is the weighted sum:<br/>𝑟=𝑤_rot(rotation toward goal)+𝑤_pos (penalty for moving away from palm)+𝑤_𝑎∥𝑎∥+𝑤_Δ𝑎∥<br/>Δ𝑎∥+𝑤_𝑣∥𝑞˙∥r=w_rot(rotation toward goal)+w_pos(penalty for moving away from palm)+w_a∥a∥+w_Δa​∥Δa∥+w_v∥q˙​∥ with weights<br/>𝑤_rot=1.0,<br/>w_rot​=1.0,<br/>𝑤_pos=−10.0,<br/>w_pos​=−10.0,<br/>𝑤_𝑎=−0.001,<br/>w_a=−0.001,<br/>𝑤_Δ𝑎=−0.25,<br/>w_Δa=−0.25,<br/>𝑤_𝑣=−0.003,<br/>w_v​=−0.003.<br/>A bonus of 250 is awarded when the cube reaches the goal orientation. This reward design encourages the policy to move the cube to the target while penalising excessive joint motions.<br/><br/>3. Simulation environment and automatic domain randomisation<br/>-Simulation with Isaac Gym: Training is done entirely in simulation using NVIDIA’s GPU‑accelerated Isaac Gym. Thousands of environments run in parallel, enabling billions of simulated frames to be processed in a few days.<br/>Domain randomisation: To bridge the sim‑to‑real gap, the authors randomise both physics parameters (mass, friction, joint stiffness, damping, etc.) and non‑physics parameters (observation and action delays, sensor noise, random forces). Table 3 in the paper lists the initial and ADR‑discovered ranges for each parameter. Noise is injected by sampling correlated and uncorrelated Gaussian noise with variances 𝜎^2 chosen by ADR. Latency and delay are randomised by sampling a delay 𝑘 from a distribution defined by ADR (applied to both actions and observations). Random pose injection occasionally replaces the estimated pose with a random one to prevent the LSTM’s hidden state from corrupting when the pose estimator fails.<br/>Vectorised automatic domain randomisation (VADR): They extend the ADR algorithm to vectorised environments. ADR maintains lower and upper bounds (𝑙_𝑖,𝑢_𝑖) for each randomisation dimension 𝑖 and widens or tightens these bounds based on policy performance at the boundaries. The algorithm samples values uniformly between [𝑙_𝑖,𝑢_𝑖] for each environment and updates boundaries when performance exceeds or falls below thresholds. This curriculum starts with narrow randomisation ranges and gradually increases them as the policy improves, producing robust policies without manual tuning.<br/>Nats per dimension metric: The amount of randomisation during training is measured by nats per dimension (npd), defined as<br/>npd=1/𝐷∑(𝑖=1)(𝐷)𝐻(𝑝_𝑖),<br/>where 𝐷 is the number of randomisation dimensions and 𝐻(𝑝_𝑖) is the entropy of the uniform distribution for parameter 𝑖. Higher npd indicates wider randomisation ranges.<br/><br/>4. Vision‑based pose estimation from synthetic data<br/>Data generation: A massive dataset of 5 million synthetic images of the cube in the hand is created using NVIDIA Omniverse Isaac Sim with Replicator. Cameras are placed randomly around the hand and various visual parameters (lighting, noise, reflections, etc.) are randomised; additional data augmentations (CutMix, random blurring, background changes, random rotations, etc.) are applied on‑the‑fly.<br/>Mask‑RCNN‑inspired pose network: The pose estimator uses a Mask‑RCNN–inspired network that first detects the cube (via bounding box and segmentation) and then regresses the 3‑D positions of its eight corners. Training uses cross‑entropy loss for segmentation and keypoints and smooth‑𝐿_1 loss for bounding‑box regression, optimised with ADAM.<br/>PnP‑based pose computation: At inference, keypoints from each camera are processed via a classic Perspective‑n‑Point (PnP) solver and triangulation to estimate the cube’s 6‑D pose; inconsistent camera estimates are filtered. This geometry‑based post‑processing makes the pose estimator independent of camera layout and more robust than previous end‑to‑end vision policies.<br/>Performance: The pose estimator achieves a mean rotation error of ~5.3° and translation errors of a few millimetres in simulation. Because the policy uses the pose estimator’s output, the entire system relies only on vision; no marker‑based motion‑capture is required.<br/><br/>5. Real‑world experiments and results<br/>Hardware: The Allegro Hand is mounted on a fixed wrist. Three Intel D415 RGB cameras provide images for pose estimation. The object is a cuboid with coloured and lettered stickers so that the vision system can distinguish faces.<br/>Performance: Policies trained with ADR achieve far more consecutive successes in the real robot than those trained with manual domain randomisation. For example, the authors report average consecutive successes of 27.8 (with a median of 14) for their best ADR model, compared with 14.8 for a manually‑randomised model. When the cube must hold the orientation for a specified number of frames, performance decreases but remains strong.<br/>Comparison with previous work: A comparison table shows that the DeXtreme system outperforms previous vision‑based policies from OpenAI et al. [2018] and is competitive with state‑estimation policies that rely on motion‑capture, while using cheaper hardware and shorter training times. Their best vision‑based rollout achieved 112 consecutive successes, exceeding the capped limit used in earlier works.<br/><br/>6. Practical insights, limitations and future directions<br/>Hardware fragility: The Allegro hand’s ribbon cables can burn out during aggressive motions; regular maintenance is necessary. Policies learned in simulation exhibit variability when deployed on real hardware (differences due to random seeds).<br/>Limitations: A noticeable sim‑to‑real gap remains; policies achieve fewer consecutive successes in the real world than in simulation and do not match the highest performance of PhaseSpace‑based systems. The vision model still has occasional failures; domain randomisation does not model joint distributions between parameters, so ADR may not explore all Pareto‑optimal solutions.<br/>Broader significance: The paper demonstrates that combining GPU‑accelerated simulation, automated domain randomisation and vision‑based pose estimation can enable low‑cost robotic hands to perform agile in‑hand manipulation. By open‑sourcing their pipelines and reducing hardware and compute barriers, the authors aim to make dexterous manipulation research more accessible and reproducible.},
   title = {DeXtreme: Transfer of Agile In-hand Manipulation from Simulation to Reality},
   url = {https://arxiv.org/pdf/2210.13702},
   year = {2024}
}
@article{Lin2025,
   abstract = {Learning generalizable robot manipulation policies, especially for complex multi-fingered humanoids, remains a significant challenge. Existing approaches primarily rely on extensive data collection and imitation learning, which are expensive, labor-intensive, and difficult to scale. Sim-to-real reinforcement learning (RL) offers a promising alternative, but has mostly succeeded in simpler state-based or single-hand setups. How to effectively extend this to vision-based, contact-rich bimanual manipulation tasks remains an open question. In this paper, we introduce a practical sim-to-real RL recipe that trains a humanoid robot to perform three challenging dexterous manipulation tasks: grasp-and-reach, box lift and bimanual handover. Our method features an automated real-to-sim tuning module, a generalized reward formulation based on contact and object goals, a divide-and-conquer policy distillation framework, and a hybrid object representation strategy with modality-specific augmentation. We demonstrate high success rates on unseen objects and robust, adaptive policy behaviors -- highlighting that vision-based dexterous manipulation via sim-to-real RL is not only viable, but also scalable and broadly applicable to real-world humanoid manipulation tasks.},
   author = {Toru Lin and Kartik Sachdev and Linxi Fan and Jitendra Malik and Yuke Zhu},
   month = {9},
   note = {- Introduction of a simple, automated <b>real-to-sim system identification method</b> to overcome this with less than four minutes of real-world data<br/><br/>- Proposal of a novel <b>keypoint-based reward formulation </b>to facilitate such coordination between hand and arms effectively.<br/><br/>- task-aware initialization strategy to accelerate single task RL, and decompose the overall multi-task (e.g. object) policy learning into separate single-task RL followed by generalist policy distillation},
   title = {Sim-to-Real Reinforcement Learning for Vision-Based Dexterous Manipulation on Humanoids},
   year = {2025}
}
@article{Huang2025,
   abstract = {Dexterous hand manipulation in real-world scenarios presents considerable challenges due to its demands for both dexterity and precision. While imitation learning approaches have thoroughly examined these challenges, they still require a significant number of expert demonstrations and are limited by a constrained performance upper bound. In this paper, we propose a novel and efficient Imitation-Bootstrapped Online Reinforcement Learning (IBORL) method tailored for robotic dexterous hand manipulation in real-world environments. Specifically, we pretrain the policy using a limited set of expert demonstrations and subsequently finetune this policy through direct reinforcement learning in the real world. To address the catastrophic forgetting issues that arise from the distribution shift between expert demonstrations and real-world environments, we design a regularization term that balances the exploration of novel behaviors with the preservation of the pretrained policy. Our experiments with real-world tasks demonstrate that our method significantly outperforms existing approaches, achieving an almost 100% success rate and a 23% improvement in cycle time. Furthermore, by finetuning with online reinforcement learning, our method surpasses expert demonstrations and uncovers superior policies. Our code and empirical results are available in https://hggforget.github.io/iborl.github.io/.},
   author = {Dongchi Huang and Tianle Zhang and Yihang Li and Ling Zhao and Jiayi Li and Zhirui Fang and Chunhe Xia and Lusong Li and Xiaodong He},
   month = {3},
   title = {Dexterous Hand Manipulation via Efficient Imitation-Bootstrapped Online Reinforcement Learning},
   year = {2025}
}
@article{Tang2024,
   abstract = {Reinforcement learning (RL), particularly its combination with deep neural networks referred to as deep RL (DRL), has shown tremendous promise across a wide range of applications, suggesting its potential for enabling the development of sophisticated robotic behaviors. Robotics problems, however, pose fundamental difficulties for the application of RL, stemming from the complexity and cost of interacting with the physical world. This article provides a modern survey of DRL for robotics, with a particular focus on evaluating the real-world successes achieved with DRL in realizing several key robotic competencies. Our analysis aims to identify the key factors underlying those exciting successes, reveal underexplored areas, and provide an overall characterization of the status of DRL in robotics. We highlight several important avenues for future work, emphasizing the need for stable and sample-efficient real-world RL paradigms, holistic approaches for discovering and integrating various competencies to tackle complex long-horizon, open-world tasks, and principled development and evaluation procedures. This survey is designed to offer insights for both RL practitioners and roboticists toward harnessing RL's power to create generally capable real-world robotic systems.},
   author = {Chen Tang and Ben Abbatematteo and Jiaheng Hu and Rohan Chandra and Roberto Martín-Martín and Peter Stone},
   month = {9},
   title = {Deep Reinforcement Learning for Robotics: A Survey of Real-World Successes},
   year = {2024}
}
